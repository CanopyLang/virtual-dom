module Test.VirtualDom exposing (main)

import Basics exposing (..)
import VirtualDom
import Json.Encode as Encode
import Json.Decode as Decode
import Maybe exposing (Maybe(..))
import String
import TestHelper
import Test exposing (Test, describe, test)
import Expect


main : Test
main =
    describe "VirtualDom"
        [ textTests
        , nodeTests
        , nodeNSTests
        , styleTests
        , propertyTests
        , attributeTests
        , attributeNSTests
        , onTests
        , keyedNodeTests
        , keyedNodeNSTests
        , mapTests
        , mapAttributeTests
        , xssSanitizationTests
        , lazyTests
        , translationRegressionTests
        , lazyInputRegressionTests
        , toHandlerIntTests
        ]



-- TEXT


textTests : Test
textTests =
    describe "text"
        [ test "creates a text node with correct content" <| \_ ->
            TestHelper.getText (VirtualDom.text "Hello")
                |> Expect.equal (Just "Hello")
        , test "empty text node has empty content" <| \_ ->
            TestHelper.getText (VirtualDom.text "")
                |> Expect.equal (Just "")
        , test "text with special characters preserves content" <| \_ ->
            TestHelper.getText (VirtualDom.text "<script>alert('xss')</script>")
                |> Expect.equal (Just "<script>alert('xss')</script>")
        , test "text with unicode preserves content" <| \_ ->
            TestHelper.getText (VirtualDom.text "Hello \u{1F600}")
                |> Expect.equal (Just "Hello \u{1F600}")
        , test "text with newlines preserves content" <| \_ ->
            TestHelper.getText (VirtualDom.text "line1\nline2\nline3")
                |> Expect.equal (Just "line1\nline2\nline3")
        , test "text node is a text node" <| \_ ->
            TestHelper.isTextNode (VirtualDom.text "Hello")
                |> Expect.equal True
        , test "text node is not an element node" <| \_ ->
            TestHelper.isElementNode (VirtualDom.text "Hello")
                |> Expect.equal False
        , test "text node has no tag" <| \_ ->
            TestHelper.getTag (VirtualDom.text "Hello")
                |> Expect.equal Nothing
        , test "different text content" <| \_ ->
            Expect.notEqual
                (TestHelper.getText (VirtualDom.text "Hello"))
                (TestHelper.getText (VirtualDom.text "World"))
        ]



-- NODE


nodeTests : Test
nodeTests =
    describe "node"
        [ test "div has correct tag" <| \_ ->
            TestHelper.getTag (VirtualDom.node "div" [] [])
                |> Expect.equal (Just "div")
        , test "span has correct tag" <| \_ ->
            TestHelper.getTag (VirtualDom.node "span" [] [])
                |> Expect.equal (Just "span")
        , test "div is an element node" <| \_ ->
            TestHelper.isElementNode (VirtualDom.node "div" [] [])
                |> Expect.equal True
        , test "div is not a text node" <| \_ ->
            TestHelper.isTextNode (VirtualDom.node "div" [] [])
                |> Expect.equal False
        , test "div is not a keyed node" <| \_ ->
            TestHelper.isKeyedNode (VirtualDom.node "div" [] [])
                |> Expect.equal False
        , test "ul has correct tag" <| \_ ->
            TestHelper.getTag (VirtualDom.node "ul" [] [])
                |> Expect.equal (Just "ul")
        , test "input has correct tag" <| \_ ->
            TestHelper.getTag (VirtualDom.node "input" [] [])
                |> Expect.equal (Just "input")
        , test "node with attributes still has correct tag" <| \_ ->
            TestHelper.getTag
                (VirtualDom.node "div"
                    [ VirtualDom.attribute "class" "container"
                    , VirtualDom.attribute "id" "main"
                    ]
                    [ VirtualDom.text "content" ]
                )
                |> Expect.equal (Just "div")
        , test "node with children still has correct tag" <| \_ ->
            TestHelper.getTag
                (VirtualDom.node "ul" []
                    [ VirtualDom.node "li" [] [ VirtualDom.text "one" ]
                    , VirtualDom.node "li" [] [ VirtualDom.text "two" ]
                    ]
                )
                |> Expect.equal (Just "ul")
        , test "different tags produce different results" <| \_ ->
            Expect.notEqual
                (TestHelper.getTag (VirtualDom.node "div" [] []))
                (TestHelper.getTag (VirtualDom.node "span" [] []))
        , test "node has no text content" <| \_ ->
            TestHelper.getText (VirtualDom.node "div" [] [])
                |> Expect.equal Nothing
        , test "node has no namespace" <| \_ ->
            TestHelper.getNamespace (VirtualDom.node "div" [] [])
                |> Expect.equal Nothing
        ]



-- NODE NS


nodeNSTests : Test
nodeNSTests =
    describe "nodeNS"
        [ test "SVG svg has correct tag" <| \_ ->
            TestHelper.getTag
                (VirtualDom.nodeNS "http://www.w3.org/2000/svg" "svg" [] [])
                |> Expect.equal (Just "svg")
        , test "SVG path has correct tag" <| \_ ->
            TestHelper.getTag
                (VirtualDom.nodeNS "http://www.w3.org/2000/svg" "path"
                    [ VirtualDom.attribute "d" "M0 0 L10 10" ]
                    []
                )
                |> Expect.equal (Just "path")
        , test "SVG circle has correct tag" <| \_ ->
            TestHelper.getTag
                (VirtualDom.nodeNS "http://www.w3.org/2000/svg" "circle"
                    [ VirtualDom.attribute "cx" "50"
                    , VirtualDom.attribute "cy" "50"
                    , VirtualDom.attribute "r" "25"
                    ]
                    []
                )
                |> Expect.equal (Just "circle")
        , test "SVG node has SVG namespace" <| \_ ->
            TestHelper.getNamespace
                (VirtualDom.nodeNS "http://www.w3.org/2000/svg" "svg" [] [])
                |> Expect.equal (Just "http://www.w3.org/2000/svg")
        , test "SVG node is an element node" <| \_ ->
            TestHelper.isElementNode
                (VirtualDom.nodeNS "http://www.w3.org/2000/svg" "svg" [] [])
                |> Expect.equal True
        , test "MathML namespace" <| \_ ->
            TestHelper.getNamespace
                (VirtualDom.nodeNS "http://www.w3.org/1998/Math/MathML" "math" [] [])
                |> Expect.equal (Just "http://www.w3.org/1998/Math/MathML")
        , test "different namespaces produce different results" <| \_ ->
            Expect.notEqual
                (TestHelper.getNamespace
                    (VirtualDom.nodeNS "http://www.w3.org/2000/svg" "g" [] []))
                (TestHelper.getNamespace
                    (VirtualDom.nodeNS "http://www.w3.org/1998/Math/MathML" "g" [] []))
        ]



-- STYLE


styleTests : Test
styleTests =
    describe "style"
        [ test "style has type tag a__1_STYLE" <| \_ ->
            TestHelper.getAttrType (VirtualDom.style "color" "red")
                |> Expect.equal "a__1_STYLE"
        , test "style has correct key" <| \_ ->
            TestHelper.getAttrKey (VirtualDom.style "color" "red")
                |> Expect.equal "color"
        , test "style has correct value" <| \_ ->
            TestHelper.getAttrValue (VirtualDom.style "color" "red")
                |> Expect.equal "red"
        , test "different style keys" <| \_ ->
            Expect.notEqual
                (TestHelper.getAttrKey (VirtualDom.style "color" "red"))
                (TestHelper.getAttrKey (VirtualDom.style "backgroundColor" "red"))
        , test "different style values" <| \_ ->
            Expect.notEqual
                (TestHelper.getAttrValue (VirtualDom.style "color" "red"))
                (TestHelper.getAttrValue (VirtualDom.style "color" "blue"))
        , test "backgroundColor style key" <| \_ ->
            TestHelper.getAttrKey (VirtualDom.style "backgroundColor" "blue")
                |> Expect.equal "backgroundColor"
        , test "width style" <| \_ ->
            TestHelper.getAttrValue (VirtualDom.style "width" "100px")
                |> Expect.equal "100px"
        , test "percentage style" <| \_ ->
            TestHelper.getAttrValue (VirtualDom.style "height" "50%")
                |> Expect.equal "50%"
        , test "display flex style" <| \_ ->
            TestHelper.getAttrValue (VirtualDom.style "display" "flex")
                |> Expect.equal "flex"
        , test "node with styles still has correct tag" <| \_ ->
            TestHelper.getTag
                (VirtualDom.node "div"
                    [ VirtualDom.style "color" "red"
                    , VirtualDom.style "fontSize" "16px"
                    ]
                    []
                )
                |> Expect.equal (Just "div")
        ]



-- PROPERTY


propertyTests : Test
propertyTests =
    describe "property"
        [ test "property has type tag a__1_PROP" <| \_ ->
            TestHelper.getAttrType (VirtualDom.property "className" (Encode.string "container"))
                |> Expect.equal "a__1_PROP"
        , test "property has correct key" <| \_ ->
            TestHelper.getAttrKey (VirtualDom.property "className" (Encode.string "container"))
                |> Expect.equal "className"
        , test "different property keys" <| \_ ->
            Expect.notEqual
                (TestHelper.getAttrKey (VirtualDom.property "className" (Encode.string "a")))
                (TestHelper.getAttrKey (VirtualDom.property "id" (Encode.string "a")))
        , test "checked property has correct key" <| \_ ->
            TestHelper.getAttrKey (VirtualDom.property "checked" (Encode.bool True))
                |> Expect.equal "checked"
        , test "tabIndex property has correct key" <| \_ ->
            TestHelper.getAttrKey (VirtualDom.property "tabIndex" (Encode.int 0))
                |> Expect.equal "tabIndex"
        , test "node with properties still has correct tag" <| \_ ->
            TestHelper.getTag
                (VirtualDom.node "input"
                    [ VirtualDom.property "type" (Encode.string "text")
                    , VirtualDom.property "value" (Encode.string "hello")
                    ]
                    []
                )
                |> Expect.equal (Just "input")
        ]



-- ATTRIBUTE


attributeTests : Test
attributeTests =
    describe "attribute"
        [ test "attribute has type tag a__1_ATTR" <| \_ ->
            TestHelper.getAttrType (VirtualDom.attribute "id" "main")
                |> Expect.equal "a__1_ATTR"
        , test "attribute has correct key" <| \_ ->
            TestHelper.getAttrKey (VirtualDom.attribute "id" "main")
                |> Expect.equal "id"
        , test "attribute has correct value" <| \_ ->
            TestHelper.getAttrValue (VirtualDom.attribute "id" "main")
                |> Expect.equal "main"
        , test "class attribute" <| \_ ->
            TestHelper.getAttrValue (VirtualDom.attribute "class" "container")
                |> Expect.equal "container"
        , test "data attribute" <| \_ ->
            TestHelper.getAttrKey (VirtualDom.attribute "data-value" "42")
                |> Expect.equal "data-value"
        , test "data attribute value" <| \_ ->
            TestHelper.getAttrValue (VirtualDom.attribute "data-value" "42")
                |> Expect.equal "42"
        , test "role attribute" <| \_ ->
            TestHelper.getAttrValue (VirtualDom.attribute "role" "button")
                |> Expect.equal "button"
        , test "aria attribute" <| \_ ->
            TestHelper.getAttrValue (VirtualDom.attribute "aria-label" "Close")
                |> Expect.equal "Close"
        , test "empty value attribute" <| \_ ->
            TestHelper.getAttrValue (VirtualDom.attribute "data-empty" "")
                |> Expect.equal ""
        , test "different attribute values" <| \_ ->
            Expect.notEqual
                (TestHelper.getAttrValue (VirtualDom.attribute "id" "main"))
                (TestHelper.getAttrValue (VirtualDom.attribute "id" "sidebar"))
        , test "different attribute names" <| \_ ->
            Expect.notEqual
                (TestHelper.getAttrKey (VirtualDom.attribute "id" "main"))
                (TestHelper.getAttrKey (VirtualDom.attribute "class" "main"))
        ]



-- ATTRIBUTE NS


attributeNSTests : Test
attributeNSTests =
    describe "attributeNS"
        [ test "attributeNS has type tag a__1_ATTR_NS" <| \_ ->
            TestHelper.getAttrType
                (VirtualDom.attributeNS "http://www.w3.org/1999/xlink" "xlink:href" "#icon")
                |> Expect.equal "a__1_ATTR_NS"
        , test "xlink:href has correct key" <| \_ ->
            TestHelper.getAttrKey
                (VirtualDom.attributeNS "http://www.w3.org/1999/xlink" "xlink:href" "#icon")
                |> Expect.equal "xlink:href"
        , test "xlink:href has correct value" <| \_ ->
            TestHelper.getAttrValue
                (VirtualDom.attributeNS "http://www.w3.org/1999/xlink" "xlink:href" "#icon")
                |> Expect.equal "#icon"
        , test "xml:lang attribute" <| \_ ->
            TestHelper.getAttrValue
                (VirtualDom.attributeNS "http://www.w3.org/XML/1998/namespace" "xml:lang" "en")
                |> Expect.equal "en"
        , test "different namespaced attribute values" <| \_ ->
            Expect.notEqual
                (TestHelper.getAttrValue
                    (VirtualDom.attributeNS "http://www.w3.org/1999/xlink" "xlink:href" "#a"))
                (TestHelper.getAttrValue
                    (VirtualDom.attributeNS "http://www.w3.org/1999/xlink" "xlink:href" "#b"))
        , test "SVG node with namespaced attribute has correct tag" <| \_ ->
            TestHelper.getTag
                (VirtualDom.nodeNS "http://www.w3.org/2000/svg" "use"
                    [ VirtualDom.attributeNS "http://www.w3.org/1999/xlink" "xlink:href" "#my-icon" ]
                    []
                )
                |> Expect.equal (Just "use")
        ]



-- ON (EVENTS)


onTests : Test
onTests =
    describe "on"
        [ test "event handler has type tag a__1_EVENT" <| \_ ->
            TestHelper.getAttrType
                (VirtualDom.on "click" (VirtualDom.Normal (Decode.succeed "clicked")))
                |> Expect.equal "a__1_EVENT"
        , test "click handler has correct event name" <| \_ ->
            TestHelper.getAttrKey
                (VirtualDom.on "click" (VirtualDom.Normal (Decode.succeed "clicked")))
                |> Expect.equal "click"
        , test "input handler has correct event name" <| \_ ->
            TestHelper.getAttrKey
                (VirtualDom.on "input"
                    (VirtualDom.Normal (Decode.field "target" (Decode.field "value" Decode.string)))
                )
                |> Expect.equal "input"
        , test "MayStopPropagation handler has correct event name" <| \_ ->
            TestHelper.getAttrKey
                (VirtualDom.on "click"
                    (VirtualDom.MayStopPropagation (Decode.succeed ( "clicked", True )))
                )
                |> Expect.equal "click"
        , test "MayPreventDefault handler has correct event name" <| \_ ->
            TestHelper.getAttrKey
                (VirtualDom.on "submit"
                    (VirtualDom.MayPreventDefault (Decode.succeed ( "submitted", True )))
                )
                |> Expect.equal "submit"
        , test "Custom handler has correct event name" <| \_ ->
            TestHelper.getAttrKey
                (VirtualDom.on "click"
                    (VirtualDom.Custom
                        (Decode.succeed
                            { message = "clicked"
                            , stopPropagation = True
                            , preventDefault = True
                            }
                        )
                    )
                )
                |> Expect.equal "click"
        , test "different event names produce different keys" <| \_ ->
            Expect.notEqual
                (TestHelper.getAttrKey
                    (VirtualDom.on "click" (VirtualDom.Normal (Decode.succeed "msg"))))
                (TestHelper.getAttrKey
                    (VirtualDom.on "submit" (VirtualDom.Normal (Decode.succeed "msg"))))
        , test "node with event handler has correct tag" <| \_ ->
            TestHelper.getTag
                (VirtualDom.node "button"
                    [ VirtualDom.on "click" (VirtualDom.Normal (Decode.succeed "click")) ]
                    [ VirtualDom.text "Click me" ]
                )
                |> Expect.equal (Just "button")
        ]



-- KEYED NODE


keyedNodeTests : Test
keyedNodeTests =
    describe "keyedNode"
        [ test "keyed node is a keyed node type" <| \_ ->
            TestHelper.isKeyedNode (VirtualDom.keyedNode "ul" [] [])
                |> Expect.equal True
        , test "keyed node is not a regular element" <| \_ ->
            TestHelper.isElementNode (VirtualDom.keyedNode "ul" [] [])
                |> Expect.equal False
        , test "keyed node has correct tag" <| \_ ->
            TestHelper.getTag (VirtualDom.keyedNode "ul" [] [])
                |> Expect.equal (Just "ul")
        , test "keyed div has correct tag" <| \_ ->
            TestHelper.getTag
                (VirtualDom.keyedNode "div"
                    [ VirtualDom.attribute "class" "list" ]
                    [ ( "a", VirtualDom.text "alpha" ) ]
                )
                |> Expect.equal (Just "div")
        , test "keyed node with styles has correct tag" <| \_ ->
            TestHelper.getTag
                (VirtualDom.keyedNode "div"
                    [ VirtualDom.style "display" "flex" ]
                    [ ( "child", VirtualDom.text "content" ) ]
                )
                |> Expect.equal (Just "div")
        ]



