-- MAP


mapTests : Test
mapTests =
    describe "map"
        [ test "map produces a tagger node" <| \_ ->
            TestHelper.isMappedNode
                (VirtualDom.map identity (VirtualDom.text "hello"))
                |> Expect.equal True
        , test "map of text is not a text node" <| \_ ->
            TestHelper.isTextNode
                (VirtualDom.map identity (VirtualDom.text "hello"))
                |> Expect.equal False
        , test "map of element is not an element node" <| \_ ->
            TestHelper.isElementNode
                (VirtualDom.map identity (VirtualDom.node "div" [] []))
                |> Expect.equal False
        ]



-- MAP ATTRIBUTE


mapAttributeTests : Test
mapAttributeTests =
    describe "mapAttribute"
        [ test "mapAttribute preserves attribute key" <| \_ ->
            TestHelper.getAttrKey
                (VirtualDom.mapAttribute identity (VirtualDom.attribute "class" "foo"))
                |> Expect.equal "class"
        , test "mapAttribute preserves attribute value" <| \_ ->
            TestHelper.getAttrValue
                (VirtualDom.mapAttribute identity (VirtualDom.attribute "id" "bar"))
                |> Expect.equal "bar"
        , test "mapAttribute preserves style key" <| \_ ->
            TestHelper.getAttrKey
                (VirtualDom.mapAttribute identity (VirtualDom.style "color" "red"))
                |> Expect.equal "color"
        , test "mapAttribute preserves style value" <| \_ ->
            TestHelper.getAttrValue
                (VirtualDom.mapAttribute identity (VirtualDom.style "color" "red"))
                |> Expect.equal "red"
        ]



-- XSS SANITIZATION


xssSanitizationTests : Test
xssSanitizationTests =
    describe "XSS Sanitization"
        [ describe "noJavaScriptUri"
            [ test "allows normal http url" <| \_ ->
                VirtualDom.noJavaScriptUri "http://example.com"
                    |> Expect.equal "http://example.com"
            , test "blocks javascript: uri" <| \_ ->
                VirtualDom.noJavaScriptUri "javascript:alert(1)"
                    |> Expect.notEqual "javascript:alert(1)"
            , test "allows https url" <| \_ ->
                VirtualDom.noJavaScriptUri "https://example.com"
                    |> Expect.equal "https://example.com"
            , test "allows relative url" <| \_ ->
                VirtualDom.noJavaScriptUri "/path/to/page"
                    |> Expect.equal "/path/to/page"
            , test "blocks JAVASCRIPT: (case insensitive)" <| \_ ->
                VirtualDom.noJavaScriptUri "JAVASCRIPT:alert(1)"
                    |> Expect.notEqual "JAVASCRIPT:alert(1)"
            , test "allows empty string" <| \_ ->
                VirtualDom.noJavaScriptUri ""
                    |> Expect.equal ""
            , test "allows hash fragment" <| \_ ->
                VirtualDom.noJavaScriptUri "#section"
                    |> Expect.equal "#section"
            ]
        , describe "noJavaScriptOrHtmlUri"
            [ test "allows normal url" <| \_ ->
                VirtualDom.noJavaScriptOrHtmlUri "https://example.com"
                    |> Expect.equal "https://example.com"
            , test "blocks javascript: uri" <| \_ ->
                VirtualDom.noJavaScriptOrHtmlUri "javascript:void(0)"
                    |> Expect.notEqual "javascript:void(0)"
            , test "blocks data:text/html" <| \_ ->
                VirtualDom.noJavaScriptOrHtmlUri "data:text/html,<script>alert(1)</script>"
                    |> Expect.notEqual "data:text/html,<script>alert(1)</script>"
            , test "allows data:image/png" <| \_ ->
                String.startsWith "data:image/png" (VirtualDom.noJavaScriptOrHtmlUri "data:image/png;base64,abc")
                    |> Expect.equal True
            ]
        , describe "noScript"
            [ test "allows normal tag" <| \_ ->
                VirtualDom.noScript "div"
                    |> Expect.equal "div"
            , test "blocks script tag" <| \_ ->
                VirtualDom.noScript "script"
                    |> Expect.notEqual "script"
            , test "blocks SCRIPT tag (case insensitive)" <| \_ ->
                VirtualDom.noScript "SCRIPT"
                    |> Expect.notEqual "SCRIPT"
            , test "allows span tag" <| \_ ->
                VirtualDom.noScript "span"
                    |> Expect.equal "span"
            ]
        ]



-- LAZY


lazyTests : Test
lazyTests =
    describe "lazy"
        [ test "lazy produces a node with correct tag when forced" <| \_ ->
            TestHelper.getTag (VirtualDom.lazy (\_ -> VirtualDom.node "div" [] []) ())
                |> Expect.equal (Just "div")
        , test "lazy2 produces a node with correct tag when forced" <| \_ ->
            TestHelper.getTag (VirtualDom.lazy2 (\_ _ -> VirtualDom.node "span" [] []) () ())
                |> Expect.equal (Just "span")
        , test "lazy3 produces a node with correct tag when forced" <| \_ ->
            TestHelper.getTag (VirtualDom.lazy3 (\_ _ _ -> VirtualDom.node "p" [] []) () () ())
                |> Expect.equal (Just "p")
        , test "lazy4 produces a node when forced" <| \_ ->
            TestHelper.isElementNode (VirtualDom.lazy4 (\_ _ _ _ -> VirtualDom.node "div" [] []) () () () ())
                |> Expect.equal True
        , test "lazy5 produces a node when forced" <| \_ ->
            TestHelper.isElementNode (VirtualDom.lazy5 (\_ _ _ _ _ -> VirtualDom.node "div" [] []) () () () () ())
                |> Expect.equal True
        , test "lazy6 produces a node when forced" <| \_ ->
            TestHelper.isElementNode (VirtualDom.lazy6 (\_ _ _ _ _ _ -> VirtualDom.node "div" [] []) () () () () () ())
                |> Expect.equal True
        , test "lazy7 produces a node when forced" <| \_ ->
            TestHelper.isElementNode (VirtualDom.lazy7 (\_ _ _ _ _ _ _ -> VirtualDom.node "div" [] []) () () () () () () ())
                |> Expect.equal True
        , test "lazy8 produces a node when forced" <| \_ ->
            TestHelper.isElementNode (VirtualDom.lazy8 (\_ _ _ _ _ _ _ _ -> VirtualDom.node "div" [] []) () () () () () () () ())
                |> Expect.equal True
        ]



-- TRANSLATION REGRESSION TESTS
--
-- These tests verify the structural invariants that the translation-detection
-- code in _VirtualDom_updateTNode relies on. The actual DOM-preservation
-- behavior (preserving browser-translated text) requires a live browser and
-- cannot be verified in a pure structural test runner.
--
-- What the translation fix does: when `domNode.data !== x.__text` after a
-- text diff, the code sets `domNode.__translated = true` instead of
-- clobbering the translated content. The fast-path in _VirtualDom_render
-- skips `textContent =` when the existing child has `__translated = true`.


translationRegressionTests : Test
translationRegressionTests =
    describe "Translation regression"
        [ test "text node captures its content in __text (used by translation detector)" <| \_ ->
            TestHelper.getText (VirtualDom.text "Hello, world!")
                |> Expect.equal (Just "Hello, world!")
        , test "empty text node has empty content" <| \_ ->
            TestHelper.getText (VirtualDom.text "")
                |> Expect.equal (Just "")
        , test "text node content is distinct from a different text node" <| \_ ->
            Expect.notEqual
                (TestHelper.getText (VirtualDom.text "before"))
                (TestHelper.getText (VirtualDom.text "after"))
        , test "text with unicode is preserved exactly" <| \_ ->
            TestHelper.getText (VirtualDom.text "Héllo wörld 🌍")
                |> Expect.equal (Just "Héllo wörld 🌍")
        ]



-- LAZY + CONTROLLED INPUT REGRESSION TESTS
--
-- These tests verify the structural invariants needed by _VirtualDom_quickVisit,
-- which is called when a lazy thunk short-circuits (refs unchanged). quickVisit
-- walks the forced vNode tree and applies live props (value, checked,
-- selectedIndex) to keep controlled inputs in sync with the model when the
-- lazy optimization skips a full re-render.


lazyInputRegressionTests : Test
lazyInputRegressionTests =
    describe "Lazy controlled input regression"
        [ test "lazy node with value property forces to an input element" <| \_ ->
            TestHelper.getTag
                (VirtualDom.lazy
                    (\val ->
                        VirtualDom.node "input"
                            [ VirtualDom.property "value" (Encode.string val) ]
                            []
                    )
                    "hello"
                )
                |> Expect.equal (Just "input")
        , test "lazy2 node with value property forces to an input element" <| \_ ->
            TestHelper.getTag
                (VirtualDom.lazy2
                    (\val _ ->
                        VirtualDom.node "input"
                            [ VirtualDom.property "value" (Encode.string val) ]
                            []
                    )
                    "world"
                    ()
                )
                |> Expect.equal (Just "input")
        , test "lazy node with checked property forces to an input element" <| \_ ->
            TestHelper.getTag
                (VirtualDom.lazy
                    (\checked ->
                        VirtualDom.node "input"
                            [ VirtualDom.property "checked" (Encode.bool checked) ]
                            []
                    )
                    True
                )
                |> Expect.equal (Just "input")
        , test "lazy wrapping a keyed node forces to a keyed node" <| \_ ->
            TestHelper.isKeyedNode
                (VirtualDom.lazy
                    (\_ ->
                        VirtualDom.keyedNode "ul" []
                            [ ( "a", VirtualDom.node "li" [] [ VirtualDom.text "item" ] ) ]
                    )
                    ()
                )
                |> Expect.equal True
        ]



-- TO HANDLER INT


toHandlerIntTests : Test
toHandlerIntTests =
    describe "toHandlerInt"
        [ test "Normal handler returns 0" <| \_ ->
            VirtualDom.toHandlerInt (VirtualDom.Normal (Decode.succeed "msg"))
                |> Expect.equal 0
        , test "MayStopPropagation handler returns 1" <| \_ ->
            VirtualDom.toHandlerInt (VirtualDom.MayStopPropagation (Decode.succeed ( "msg", True )))
                |> Expect.equal 1
        , test "MayPreventDefault handler returns 2" <| \_ ->
            VirtualDom.toHandlerInt (VirtualDom.MayPreventDefault (Decode.succeed ( "msg", True )))
                |> Expect.equal 2
        , test "Custom handler returns 3" <| \_ ->
            VirtualDom.toHandlerInt
                (VirtualDom.Custom
                    (Decode.succeed
                        { message = "msg"
                        , stopPropagation = False
                        , preventDefault = False
                        }
                    )
                )
                |> Expect.equal 3
        ]
